{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Vite usa resolución bundler — sobreescribimos NodeNext del base
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@tokens/*": ["../../packages/design-tokens/src/*"],
      "@theme/*": ["../../packages/bootstrap-theme/src/*"]
    }
  },
  "include": ["src", "vite.config.ts", "vitest.config.ts", "playwright.config.ts"]
}
