{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Vite usa resolución bundler — sobreescribimos NodeNext del base
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts"]
}
