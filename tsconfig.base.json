{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // --- Objetivo de compilación ---
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    // --- Alias de rutas compartidas (baseUrl = monorepo root) ---
    "baseUrl": ".",
    "paths": {
      "@tokens/*": ["packages/design-tokens/src/*"],
      "@theme/*": ["packages/bootstrap-theme/src/*"]
    },

    // --- Modo estricto completo ---
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noPropertyAccessFromIndexSignature": true,
    "forceConsistentCasingInFileNames": true,

    // --- Compatibilidad e interoperabilidad ---
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    // --- Salida ---
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  // Sin archivos propios — este config solo es base para extender en cada paquete
  "files": []
}
